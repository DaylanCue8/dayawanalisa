-- 1. Create the Database (Optional if you already have one)
CREATE DATABASE IF NOT EXISTS dayaw;
USE dayaw;

-- 1. Table for tracking the overall translation attempt
CREATE TABLE processing_sessions (
    session_id INT AUTO_INCREMENT PRIMARY KEY,
    status VARCHAR(50) DEFAULT 'Processing', -- Success, Low_Confidence, Failed
    device_info VARCHAR(100) DEFAULT 'Mobile',
    ip_address VARCHAR(45),
    start_time TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    end_time TIMESTAMP NULL ON UPDATE CURRENT_TIMESTAMP
);

-- 2. Table for granular character-by-character feedback
CREATE TABLE detection_logs (
    log_id INT AUTO_INCREMENT PRIMARY KEY,
    session_id INT,
    detected_char VARCHAR(10), -- e.g., 'NGA', 'LA', 'BA'
    confidence_score FLOAT,    -- e.g., 85.5
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (session_id) REFERENCES processing_sessions(session_id) ON DELETE CASCADE
);



-- NOT IN DATABASE SCHEMA BUT RELEVANT FOR FRONTEND:

-- 3. Table for User Accounts/Profiles
-- Supports Objective 4: Tracking learning progress and improvement rates
CREATE TABLE users (
    user_id INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(50) NOT NULL UNIQUE,
    password_hash VARCHAR(255) NOT NULL, -- For security during White-box testing
    full_name VARCHAR(100),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 4. Table for Archiving Translations
-- Supports Objective 1.3: Digital documentation and "view and copy" features
CREATE TABLE translation_history (
    history_id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT,
    session_id INT,
    input_type ENUM('Image', 'Text') NOT NULL, -- Distinguishes BTT vs TTB
    raw_input TEXT, -- Stores the Tagalog text or the path to the uploaded image
    final_output TEXT, -- Stores the "NGALABA" or Baybayin script result
    is_bookmarked BOOLEAN DEFAULT FALSE, -- Allows users to "archive" favorite translations
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(user_id) ON DELETE CASCADE,
    FOREIGN KEY (session_id) REFERENCES processing_sessions(session_id) ON DELETE SET NULL
);